# =============================================================================
# Configuration frontend DigiID
# Copier en .env.local et adapter.
# =============================================================================

# URL du backend API
# En développement : http://localhost:8000
# En production    : https://api.digiid.africa
URL_BACKEND=http://localhost:8000

# Nom de l'application affiché dans l'interface
NEXT_PUBLIC_NOM_APPLICATION=DigiID
