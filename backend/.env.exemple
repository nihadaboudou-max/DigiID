# =============================================================================
# DigiID — Configuration d'environnement
# Copier ce fichier en .env et adapter les valeurs.
# NE JAMAIS COMMITTER LE .env AVEC DE VRAIS SECRETS.
# =============================================================================

# --- Application ---
ENVIRONNEMENT=developpement              # developpement | test | production
NOM_APPLICATION=DigiID
VERSION_API=v1
DEBUG=true

# --- Sécurité ---
# Générer une clé JWT :
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Générer une clé de chiffrement AES (32 octets base64) :
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Si des clés ont fuité : régénérer JWT + chiffrement ici, et révoquer GROQ/OPENROUTER sur leurs sites.
CLE_SECRETE_JWT=REMPLACER_PAR_UNE_CLE_JWT_ALEATOIRE_DE_64_CARACTERES_MINIMUM
CLE_CHIFFREMENT_DONNEES=REMPLACER_PAR_32_OCTETS_ALEATOIRES_EN_BASE64
ALGORITHME_JWT=HS256
DUREE_TOKEN_ACCES_MINUTES=15
DUREE_TOKEN_RAFRAICHISSEMENT_JOURS=7

# --- Base de données PostgreSQL ---
POSTGRES_HOST=base_donnees
POSTGRES_PORT=5432
POSTGRES_UTILISATEUR=digiid_user
POSTGRES_MOT_DE_PASSE=mot_de_passe_postgres_dev
POSTGRES_NOM_BASE=digiid

# --- Redis (cache + sessions + Celery) ---
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_MOT_DE_PASSE=

# --- LLM (chatbot) ---
# Fournisseur : ollama (dev local) | groq (prod gratuit) | openrouter (fallback)
FOURNISSEUR_LLM=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODELE=mistral:7b-instruct
GROQ_API_KEY=
GROQ_MODELE=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODELE=meta-llama/llama-3.3-70b-instruct:free

# --- Vector store (RAG chatbot) ---
CHROMADB_HOST=base_vectorielle
CHROMADB_PORT=8000

# --- Reconnaissance faciale ---
MODELE_FACE_RECOGNITION=insightface       # insightface | dlib
SEUIL_SIMILARITE_VISAGE=0.6               # 0 = identique, 1 = différent
ACTIVER_LISTE_PERSONNES_RECHERCHEES=false # mettre à true avec consentement

# --- Monitoring ---
NIVEAU_JOURNAL=INFO                       # DEBUG | INFO | WARNING | ERROR | CRITICAL
SENTRY_DSN=
ACTIVER_METRIQUES_PROMETHEUS=true

# --- CORS ---
ORIGINES_AUTORISEES=http://localhost:3000,http://127.0.0.1:3000

# --- Limitations de débit (rate limiting) ---
LIMITE_REQUETES_PAR_MINUTE_ANONYME=20
LIMITE_REQUETES_PAR_MINUTE_AUTHENTIFIE=120
LIMITE_REQUETES_PAR_MINUTE_ADMIN=300

# --- Détection de fraude ---
SEUIL_SCORE_RISQUE_BLOCAGE=80             # 0-100, action bloquée si >= seuil
SEUIL_TENTATIVES_CONNEXION_ECHEC=5        # verrouillage après N échecs

# --- 2FA / Authentification multi-facteurs ---
# Mettre à true une fois l'activation 2FA disponible dans le profil admin
ACTIVER_2FA_OBLIGATOIRE_ADMIN=false
DUREE_VALIDITE_CODE_2FA_SECONDES=300
