# Note importante : le fichier .env doit se trouver dans le dossier ../backend/
# Le docker-compose le charge automatiquement via : env_file: ../backend/.env
#
# Pour démarrer :
#   1. cp ../backend/.env.exemple ../backend/.env
#   2. Éditer ../backend/.env (notamment changer les CLE_SECRETE_JWT et CLE_CHIFFREMENT_DONNEES)
#   3. docker compose up -d
